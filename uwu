<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Vive el Ciclo</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Segoe UI', Arial, sans-serif;
  background: #1a1a2e;
  color: #f0f0f0;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}
#app {
  width: 100%;
  max-width: 480px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* INICIO */
#screen-inicio {
  width: 100%; min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 32px 24px; text-align: center;
}
.titulo-juego {
  font-size: 2.4rem; font-weight: 900; letter-spacing: 2px; margin-bottom: 8px;
  background: linear-gradient(90deg, #e94560, #f5a623, #7ed321, #9b59b6);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.subtitulo { font-size: 1rem; color: #aaa; margin-bottom: 28px; }
.fases-preview { display: flex; gap: 10px; margin-bottom: 28px; flex-wrap: wrap; justify-content: center; }
.fase-chip { padding: 6px 14px; border-radius: 20px; font-size: 0.82rem; font-weight: 600; }
.chip-menstrual { background: #e9456022; border: 2px solid #e94560; color: #e94560; }
.chip-folicular { background: #7ed32122; border: 2px solid #7ed321; color: #7ed321; }
.chip-ovulatoria { background: #f5a62322; border: 2px solid #f5a623; color: #f5a623; }
.chip-lutea { background: #9b59b622; border: 2px solid #9b59b6; color: #9b59b6; }
.instrucciones {
  background: #ffffff12; border-radius: 16px; padding: 18px; margin-bottom: 28px;
  font-size: 0.9rem; line-height: 1.7; color: #ddd; text-align: left; width: 100%;
}
.btn-principal {
  background: linear-gradient(135deg, #e94560, #c0392b); color: white; border: none;
  padding: 18px 48px; font-size: 1.2rem; font-weight: 700; border-radius: 50px;
  cursor: pointer; letter-spacing: 1px; box-shadow: 0 4px 20px #e9456055;
  width: 100%; max-width: 320px; transition: transform 0.1s;
}
.btn-principal:active { transform: scale(0.97); }

/* FASE */
#screen-fase {
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column; align-items: center;
}
.fase-imagen-container { width: 100%; position: relative; }
.fase-imagen-container img {
  width: 100%; display: block;
  max-height: 52vw; object-fit: cover; object-position: center top;
}
.fase-label-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 16px 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.85));
  text-align: center;
}
.fase-nombre { font-size: 1.4rem; font-weight: 900; letter-spacing: 1px; }
.fase-dias { font-size: 0.88rem; opacity: 0.85; margin-top: 2px; }
.fase-body { width: 100%; padding: 16px 18px; flex: 1; }
.fase-body p { font-size: 0.93rem; line-height: 1.65; color: #ccc; margin-bottom: 16px; }
.btn-cuerpo {
  width: 100%; padding: 13px; font-size: 0.92rem; font-weight: 700;
  border-radius: 14px; cursor: pointer; border: 2px solid; margin-bottom: 12px;
  background: transparent; transition: background 0.15s;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-continuar-fase {
  width: 100%; padding: 16px; font-size: 1.05rem; font-weight: 700;
  border: none; border-radius: 50px; cursor: pointer; transition: transform 0.1s;
}
.btn-continuar-fase:active { transform: scale(0.97); }

/* PREGUNTA */
#screen-pregunta {
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column;
}
.preg-img-container { width: 100%; position: relative; flex-shrink: 0; }
.preg-img-container img {
  width: 100%; display: block;
  max-height: 42vw; object-fit: cover; object-position: center top;
}
.preg-fase-bar {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 16px 14px 8px;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  display: flex; align-items: center; justify-content: space-between;
}
.preg-fase-badge {
  font-size: 0.78rem; font-weight: 700; padding: 3px 10px; border-radius: 20px;
}
.preg-numero { font-size: 0.8rem; color: #ddd; }
.progreso-bar-wrap { width: 100%; padding: 10px 16px 6px; }
.progreso-bar { width: 100%; height: 5px; background: #ffffff22; border-radius: 3px; overflow: hidden; }
.progreso-fill { height: 100%; border-radius: 3px; transition: width 0.4s; }
.escenario-box { width: 100%; padding: 10px 16px 12px; }
.escenario-texto {
  background: #ffffff0e; border-radius: 14px; padding: 14px 16px;
  font-size: 0.93rem; line-height: 1.6; color: #eee; font-style: italic;
  border-left: 4px solid currentColor;
}
.opciones-lista {
  width: 100%; padding: 0 16px; display: flex; flex-direction: column;
  gap: 10px; flex: 1;
}
.btn-opcion {
  width: 100%; padding: 14px 16px; font-size: 0.92rem; line-height: 1.45;
  text-align: left; background: #ffffff10; border: 2px solid #ffffff22;
  border-radius: 14px; color: #eee; cursor: pointer; transition: background 0.15s;
}
.btn-opcion:active { background: #ffffff22; }
.btn-cuerpo-preg {
  margin: 10px 16px 0; padding: 11px; font-size: 0.85rem; font-weight: 700;
  border-radius: 12px; cursor: pointer; border: 2px solid;
  background: transparent; display: flex; align-items: center; justify-content: center; gap: 6px;
}
.spacer { height: 20px; }

/* FEEDBACK */
#screen-feedback {
  width: 100%; min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: space-between;
}
.feedback-top {
  width: 100%; flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; padding: 40px 24px 24px; text-align: center;
}
.feedback-icono { font-size: 3.5rem; margin-bottom: 14px; }
.feedback-resultado { font-size: 1.5rem; font-weight: 900; margin-bottom: 18px; letter-spacing: 1px; }
.feedback-explicacion { font-size: 0.97rem; line-height: 1.75; max-width: 400px; }
.feedback-bottom { width: 100%; padding: 14px 20px 32px; }
.btn-siguiente {
  width: 100%; padding: 17px; font-size: 1.05rem; font-weight: 700;
  border: none; border-radius: 50px; cursor: pointer; letter-spacing: 1px; transition: transform 0.1s;
}
.btn-siguiente:active { transform: scale(0.97); }

/* RESULTADOS */
#screen-resultados {
  width: 100%; min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
  display: flex; flex-direction: column; align-items: center;
  padding: 40px 24px 32px; text-align: center;
}
.resultados-titulo {
  font-size: 1.7rem; font-weight: 900; margin-bottom: 6px;
  background: linear-gradient(90deg, #f5a623, #e94560);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.resultados-subtitulo { font-size: 0.88rem; color: #aaa; margin-bottom: 28px; }
.fases-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; width: 100%; margin-bottom: 24px; }
.fase-resultado-card {
  border-radius: 16px; padding: 16px 10px;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
}
.fase-resultado-icono { font-size: 2rem; }
.fase-resultado-nombre { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.5px; opacity: 0.9; }
.fase-resultado-puntaje { font-size: 1.4rem; font-weight: 900; }
.total-box {
  background: linear-gradient(135deg, #f5a62333, #e9456033);
  border: 2px solid #f5a623; border-radius: 20px; padding: 22px 40px;
  margin-bottom: 28px; width: 100%;
}
.total-label { font-size: 0.88rem; color: #f5a623; font-weight: 600; margin-bottom: 4px; }
.total-numero { font-size: 2.8rem; font-weight: 900; color: #f5a623; }
.total-max { font-size: 0.95rem; color: #aaa; }
.mensaje-final { font-size: 0.93rem; color: #ccc; line-height: 1.6; margin-bottom: 24px; }
.btn-reiniciar {
  background: linear-gradient(135deg, #e94560, #c0392b); color: white; border: none;
  padding: 16px 40px; font-size: 1rem; font-weight: 700; border-radius: 50px;
  cursor: pointer; width: 100%; max-width: 320px; transition: transform 0.1s;
}
.btn-reiniciar:active { transform: scale(0.97); }

/* MODAL CUERPO */
#modal-cuerpo {
  display: none; position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.88);
  align-items: center; justify-content: center; padding: 16px;
}
#modal-cuerpo.visible { display: flex; }
.modal-inner {
  background: #16213e; border-radius: 24px; width: 100%; max-width: 440px;
  max-height: 92vh; overflow-y: auto; padding: 24px 20px 20px;
  position: relative;
}
.modal-close {
  position: absolute; top: 14px; right: 16px;
  background: #ffffff22; border: none; color: #fff; font-size: 1.2rem;
  width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.modal-titulo { font-size: 1.1rem; font-weight: 900; margin-bottom: 4px; }
.modal-subtitulo { font-size: 0.8rem; color: #aaa; margin-bottom: 16px; }
.modal-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
.modal-tab {
  flex: 1; padding: 10px; font-size: 0.85rem; font-weight: 700;
  border-radius: 12px; border: 2px solid; cursor: pointer; background: transparent;
  transition: background 0.15s;
}
.modal-tab.active { color: #fff !important; }
.modal-utero-img { width: 100%; border-radius: 14px; display: block; margin-bottom: 14px; background: #fff; }
.modal-desc {
  font-size: 0.9rem; line-height: 1.65; color: #ccc;
  background: #ffffff0a; border-radius: 12px; padding: 14px;
}
.cerebro-container { width: 100%; margin-bottom: 14px; }

.hidden { display: none !important; }
</style>
</head>
<body>
<div id="app">

<!-- INICIO -->
<div id="screen-inicio">
  <div class="titulo-juego">🌸 Vive el Ciclo</div>
  <div class="subtitulo">Un juego sobre el ciclo menstrual</div>
  <div class="fases-preview">
    <span class="fase-chip chip-menstrual">🔴 Menstrual</span>
    <span class="fase-chip chip-folicular">🌱 Folicular</span>
    <span class="fase-chip chip-ovulatoria">✨ Ovulatoria</span>
    <span class="fase-chip chip-lutea">🌙 Lútea</span>
  </div>
  <div class="instrucciones">
    <p>🎮 <strong>¿Cómo se juega?</strong></p>
    <p>Vivirás el ciclo menstrual desde adentro. En cada fase enfrentarás situaciones cotidianas reales y deberás tomar la mejor decisión.</p>
    <p style="margin-top:10px">📊 <strong>12 preguntas</strong> · <strong>4 fases</strong> · <strong>3 puntos por fase</strong></p>
  </div>
  <button class="btn-principal" onclick="iniciarJuego()">¡Comenzar! →</button>
</div>

<!-- FASE -->
<div id="screen-fase" class="hidden">
  <div class="fase-imagen-container">
    <img id="fase-img" src="" alt="">
    <div class="fase-label-overlay">
      <div class="fase-nombre" id="fase-nombre-texto"></div>
      <div class="fase-dias" id="fase-dias-texto"></div>
    </div>
  </div>
  <div class="fase-body">
    <p id="fase-desc-texto"></p>
    <button class="btn-cuerpo" id="btn-cuerpo-fase" onclick="abrirModal()">
      🔬 ¿Qué pasa en tu cuerpo?
    </button>
    <button class="btn-continuar-fase" id="btn-continuar-fase" onclick="irAPregunta()">
      Comenzar fase →
    </button>
  </div>
</div>

<!-- PREGUNTA -->
<div id="screen-pregunta" class="hidden">
  <div class="preg-img-container">
    <img id="preg-img" src="" alt="">
    <div class="preg-fase-bar">
      <span class="preg-fase-badge" id="preg-fase-badge"></span>
      <span class="preg-numero" id="preg-numero"></span>
    </div>
  </div>
  <div class="progreso-bar-wrap">
    <div class="progreso-bar">
      <div class="progreso-fill" id="progreso-fill"></div>
    </div>
  </div>
  <div class="escenario-box">
    <div class="escenario-texto" id="preg-escenario"></div>
  </div>
  <div class="opciones-lista" id="opciones-lista"></div>
  <button class="btn-cuerpo-preg" id="btn-cuerpo-preg" onclick="abrirModal()">
    🔬 ¿Qué pasa en tu cuerpo?
  </button>
  <div class="spacer"></div>
</div>

<!-- FEEDBACK -->
<div id="screen-feedback" class="hidden">
  <div class="feedback-top">
    <div class="feedback-icono" id="fb-icono"></div>
    <div class="feedback-resultado" id="fb-resultado"></div>
    <div class="feedback-explicacion" id="fb-explicacion"></div>
  </div>
  <div class="feedback-bottom">
    <button class="btn-siguiente" id="btn-siguiente" onclick="siguientePregunta()"></button>
  </div>
</div>

<!-- RESULTADOS -->
<div id="screen-resultados" class="hidden">
  <div class="resultados-titulo">¡Ciclo completado! 🎉</div>
  <div class="resultados-subtitulo">Así conociste tu cuerpo desde adentro</div>
  <div class="fases-grid" id="fases-grid-resultados"></div>
  <div class="total-box">
    <div class="total-label">PUNTAJE TOTAL</div>
    <div class="total-numero" id="total-numero"></div>
    <div class="total-max">de 12 puntos</div>
  </div>
  <div class="mensaje-final" id="mensaje-final"></div>
  <button class="btn-reiniciar" onclick="reiniciar()">🔄 Jugar de nuevo</button>
</div>

<!-- MODAL CUERPO -->
<div id="modal-cuerpo">
  <div class="modal-inner">
    <button class="modal-close" onclick="cerrarModal()">✕</button>
    <div class="modal-titulo" id="modal-titulo"></div>
    <div class="modal-subtitulo" id="modal-subtitulo"></div>
    <div class="modal-tabs">
      <button class="modal-tab" id="tab-utero" onclick="mostrarTab('utero')">🫁 Útero</button>
      <button class="modal-tab" id="tab-cerebro" onclick="mostrarTab('cerebro')">🧠 Cerebro</button>
    </div>
    <div id="panel-utero">
      <img class="modal-utero-img" id="modal-utero-img" src="" alt="Útero">
      <div class="modal-desc" id="modal-utero-desc"></div>
    </div>
    <div id="panel-cerebro" class="hidden">
      <div class="cerebro-container">
        <svg id="cerebro-svg" viewBox="0 0 300 220" xmlns="http://www.w3.org/2000/svg" style="width:100%;border-radius:14px;background:#0d1117"></svg>
      </div>
      <div class="modal-desc" id="modal-cerebro-desc"></div>
    </div>
  </div>
</div>

</div><!-- /app -->

