let faseActual = 0, preguntaActual = 0, puntajes = [0,0,0,0];
let tabActual = 'utero';

function mostrarPantalla(id) {
  ['screen-inicio','screen-fase','screen-pregunta','screen-feedback','screen-resultados']
    .forEach(s => document.getElementById(s).classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
  window.scrollTo(0,0);
}

function iniciarJuego() {
  faseActual = 0; preguntaActual = 0; puntajes = [0,0,0,0];
  mostrarFase();
}

function aplicarColorFase(fase) {
  document.querySelectorAll('.btn-cuerpo, .btn-cuerpo-preg').forEach(b => {
    b.style.borderColor = fase.color;
    b.style.color = fase.color;
  });
}

function mostrarFase() {
  const fase = FASES[faseActual];
  document.getElementById('fase-img').src = IMGS[fase.img];
  document.getElementById('fase-nombre-texto').textContent = fase.emoji + ' ' + fase.nombre;
  document.getElementById('fase-nombre-texto').style.color = fase.color;
  document.getElementById('fase-dias-texto').textContent = fase.dias;
  document.getElementById('fase-desc-texto').textContent = fase.descripcion;
  const btnC = document.getElementById('btn-continuar-fase');
  btnC.style.background = fase.btnColor;
  btnC.style.color = '#fff';
  aplicarColorFase(fase);
  mostrarPantalla('screen-fase');
}

function irAPregunta() { mostrarPregunta(); }

function mostrarPregunta() {
  const fase = FASES[faseActual];
  const preg = fase.preguntas[preguntaActual];
  const totalPregs = FASES.reduce((a,f) => a + f.preguntas.length, 0);
  const pregGlobal = FASES.slice(0,faseActual).reduce((a,f) => a + f.preguntas.length, 0) + preguntaActual + 1;

  document.getElementById('preg-img').src = IMGS[fase.img];
  const badge = document.getElementById('preg-fase-badge');
  badge.textContent = fase.emoji + ' ' + fase.nombre;
  badge.style.background = fase.badgeBg;
  badge.style.color = fase.color;
  document.getElementById('preg-numero').textContent = 'Pregunta ' + pregGlobal + ' / ' + totalPregs;

  const fill = document.getElementById('progreso-fill');
  fill.style.width = ((pregGlobal-1)/totalPregs*100) + '%';
  fill.style.background = fase.progresoBg;

  document.getElementById('preg-escenario').textContent = preg.escenario;
  document.getElementById('preg-escenario').style.borderLeftColor = fase.color;

  const lista = document.getElementById('opciones-lista');
  lista.innerHTML = '';
  preg.opciones.forEach((op, i) => {
    const btn = document.createElement('button');
    btn.className = 'btn-opcion';
    btn.textContent = String.fromCharCode(65+i) + ') ' + op;
    btn.onclick = () => responder(i);
    lista.appendChild(btn);
  });

  const btnCp = document.getElementById('btn-cuerpo-preg');
  btnCp.style.borderColor = fase.color;
  btnCp.style.color = fase.color;

  mostrarPantalla('screen-pregunta');
}

function responder(idx) {
  const fase = FASES[faseActual];
  const preg = fase.preguntas[preguntaActual];
  const correcto = idx === preg.correcta;
  if (correcto) puntajes[faseActual]++;

  const fb = document.getElementById('screen-feedback');
  if (correcto) {
    fb.style.background = 'linear-gradient(135deg,#1a4a1a,#145214)';
    document.getElementById('fb-icono').textContent = '✅';
    document.getElementById('fb-resultado').textContent = '¡Correcto!';
    document.getElementById('fb-resultado').style.color = '#7ed321';
    document.getElementById('fb-explicacion').textContent = preg.explicacionCorrecta;
  } else {
    fb.style.background = 'linear-gradient(135deg,#4a1a1a,#521414)';
    document.getElementById('fb-icono').textContent = '❌';
    document.getElementById('fb-resultado').textContent = 'No era esa';
    document.getElementById('fb-resultado').style.color = '#e94560';
    document.getElementById('fb-explicacion').textContent = preg.explicacionIncorrecta;
  }

  const esFin = (preguntaActual === fase.preguntas.length-1) && (faseActual === FASES.length-1);
  const esFinFase = preguntaActual === fase.preguntas.length-1;
  const btnSig = document.getElementById('btn-siguiente');
  if (esFin) { btnSig.textContent = 'Ver resultados →'; btnSig.style.background = 'linear-gradient(135deg,#f5a623,#d4891a)'; }
  else if (esFinFase) { btnSig.textContent = 'Siguiente fase →'; btnSig.style.background = fase.btnColor; }
  else { btnSig.textContent = 'Siguiente pregunta →'; btnSig.style.background = fase.btnColor; }

  mostrarPantalla('screen-feedback');
}

function siguientePregunta() {
  const fase = FASES[faseActual];
  const esFinFase = preguntaActual === fase.preguntas.length-1;
  const esFin = esFinFase && (faseActual === FASES.length-1);
  if (esFin) mostrarResultados();
  else if (esFinFase) { faseActual++; preguntaActual = 0; mostrarFase(); }
  else { preguntaActual++; mostrarPregunta(); }
}

function mostrarResultados() {
  const grid = document.getElementById('fases-grid-resultados');
  grid.innerHTML = '';
  FASES.forEach((fase, i) => {
    const card = document.createElement('div');
    card.className = 'fase-resultado-card';
    card.style.background = fase.bgCard;
    card.style.border = '2px solid ' + fase.color;
    card.innerHTML = `<div class="fase-resultado-icono">${fase.emoji}</div><div class="fase-resultado-nombre" style="color:${fase.color}">${fase.nombre}</div><div class="fase-resultado-puntaje" style="color:${fase.color}">${puntajes[i]}/3</div>`;
    grid.appendChild(card);
  });
  const total = puntajes.reduce((a,b)=>a+b,0);
  document.getElementById('total-numero').textContent = total + '/12';
  let msg = '';
  if (total===12) msg = '¡Puntaje perfecto! Conoces muy bien cómo funciona tu cuerpo a lo largo del ciclo.';
  else if (total>=9) msg = '¡Muy bien! Tienes una comprensión sólida del ciclo menstrual.';
  else if (total>=6) msg = 'Buen intento. Ya tienes bases importantes para entender mejor tu cuerpo.';
  else msg = 'El ciclo menstrual es complejo y fascinante. Cada pregunta te enseñó algo nuevo sobre tu cuerpo.';
  document.getElementById('mensaje-final').textContent = msg;
  mostrarPantalla('screen-resultados');
}

// ===== MODAL CUERPO =====
function abrirModal() {
  const fase = FASES[faseActual];
  document.getElementById('modal-titulo').textContent = '🔬 Tu cuerpo en la ' + fase.nombre;
  document.getElementById('modal-titulo').style.color = fase.color;
  document.getElementById('modal-subtitulo').textContent = fase.dias;
  document.getElementById('modal-utero-img').src = UTEROS[fase.id];
  document.getElementById('modal-utero-desc').textContent = fase.uteroDesc;
  document.getElementById('modal-cerebro-desc').textContent = fase.cerebroDesc;

  const tabU = document.getElementById('tab-utero');
  const tabC = document.getElementById('tab-cerebro');
  tabU.style.borderColor = fase.color; tabU.style.color = fase.color;
  tabC.style.borderColor = fase.color; tabC.style.color = fase.color;

  dibujarCerebro(fase);
  mostrarTab('utero');
  document.getElementById('modal-cuerpo').classList.add('visible');
}

function cerrarModal() {
  document.getElementById('modal-cuerpo').classList.remove('visible');
}

function mostrarTab(tab) {
  tabActual = tab;
  const fase = FASES[faseActual];
  document.getElementById('panel-utero').classList.toggle('hidden', tab !== 'utero');
  document.getElementById('panel-cerebro').classList.toggle('hidden', tab !== 'cerebro');
  const tabU = document.getElementById('tab-utero');
  const tabC = document.getElementById('tab-cerebro');
  if (tab === 'utero') {
    tabU.classList.add('active'); tabU.style.background = fase.color;
    tabC.classList.remove('active'); tabC.style.background = 'transparent';
  } else {
    tabC.classList.add('active'); tabC.style.background = fase.color;
    tabU.classList.remove('active'); tabU.style.background = 'transparent';
  }
}

function dibujarCerebro(fase) {
  const svg = document.getElementById('cerebro-svg');
  svg.innerHTML = '';

  // Forma del cerebro (SVG path simplificado)
  const silueta = document.createElementNS('http://www.w3.org/2000/svg','ellipse');
  silueta.setAttribute('cx','150'); silueta.setAttribute('cy','105');
  silueta.setAttribute('rx','105'); silueta.setAttribute('ry','80');
  silueta.setAttribute('fill','#1e2a3a'); silueta.setAttribute('stroke','#334');
  silueta.setAttribute('stroke-width','2');
  svg.appendChild(silueta);

  // Línea central
  const linea = document.createElementNS('http://www.w3.org/2000/svg','line');
  linea.setAttribute('x1','150'); linea.setAttribute('y1','30');
  linea.setAttribute('x2','150'); linea.setAttribute('y2','175');
  linea.setAttribute('stroke','#334'); linea.setAttribute('stroke-width','1.5');
  svg.appendChild(linea);

  // Circunvoluciones decorativas
  [[100,65,40,15],[180,80,35,12],[120,130,45,14],[175,135,30,12]].forEach(([cx,cy,rx,ry]) => {
    const e = document.createElementNS('http://www.w3.org/2000/svg','ellipse');
    e.setAttribute('cx',cx); e.setAttribute('cy',cy);
    e.setAttribute('rx',rx); e.setAttribute('ry',ry);
    e.setAttribute('fill','none'); e.setAttribute('stroke','#2a3a4a'); e.setAttribute('stroke-width','1.5');
    svg.appendChild(e);
  });

  // Zonas activas con animación
  fase.cerebroZonas.forEach((zona, idx) => {
    const g = document.createElementNS('http://www.w3.org/2000/svg','g');

    // Halo exterior pulsante
    const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');
    halo.setAttribute('cx', zona.x); halo.setAttribute('cy', zona.y);
    halo.setAttribute('r', zona.r + 10);
    halo.setAttribute('fill', zona.color + '33');
    const animHalo = document.createElementNS('http://www.w3.org/2000/svg','animate');
    animHalo.setAttribute('attributeName','r');
    animHalo.setAttribute('values', `${zona.r+4};${zona.r+14};${zona.r+4}`);
    animHalo.setAttribute('dur', `${1.8 + idx*0.3}s`);
    animHalo.setAttribute('repeatCount','indefinite');
    if (zona.intensidad > 0.5) halo.appendChild(animHalo);
    g.appendChild(halo);

    // Círculo principal
    const circ = document.createElementNS('http://www.w3.org/2000/svg','circle');
    circ.setAttribute('cx', zona.x); circ.setAttribute('cy', zona.y);
    circ.setAttribute('r', zona.r);
    circ.setAttribute('fill', zona.color);
    circ.setAttribute('opacity', zona.intensidad);
    g.appendChild(circ);

    // Etiqueta
    if (zona.etiqueta) {
      const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
      txt.setAttribute('x', zona.x); txt.setAttribute('y', zona.y + zona.r + 12);
      txt.setAttribute('text-anchor','middle'); txt.setAttribute('fill','#fff');
      txt.setAttribute('font-size','8'); txt.setAttribute('font-weight','bold');
      txt.textContent = zona.etiqueta;
      g.appendChild(txt);
    }

    svg.appendChild(g);
  });

  // Leyenda fase
  const leyenda = document.createElementNS('http://www.w3.org/2000/svg','text');
  leyenda.setAttribute('x','150'); leyenda.setAttribute('y','208');
  leyenda.setAttribute('text-anchor','middle');
  leyenda.setAttribute('fill', fase.color);
  leyenda.setAttribute('font-size','10'); leyenda.setAttribute('font-weight','bold');
  leyenda.textContent = fase.emoji + ' ' + fase.nombre + ' — ' + fase.dias;
  svg.appendChild(leyenda);
}

function reiniciar() { iniciarJuego(); }

// Cerrar modal al tocar fuera
document.getElementById('modal-cuerpo').addEventListener('click', function(e) {
  if (e.target === this) cerrarModal();
});
